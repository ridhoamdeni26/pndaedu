# -----------------------------------------------------------------------------
#  PandaEducation - docker-compose .env
#  Copy this file to .env (in this folder) and adjust if needed.
#    cp .env.example .env
# -----------------------------------------------------------------------------

# ---- App (Laravel) ----------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Host ports (change if 8000/5173 already in use on your machine)
APP_PORT=8000
VITE_PORT=5173

# ---- PostgreSQL -------------------------------------------------------------
DB_DATABASE=pandaeducation
DB_USERNAME=panda
DB_PASSWORD=panda_secret
DB_PORT_HOST=5432

# ---- Redis ------------------------------------------------------------------
REDIS_PORT_HOST=6379

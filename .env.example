# -----------------------------------------------------------------------------
#  PandaEducation - docker-compose .env template
#  cp .env.example .env
# -----------------------------------------------------------------------------

APP_ENV=local
APP_DEBUG=true
APP_URL=http://pandaeducation.test

# Port 80 = akses via http://pandaeducation.test (tanpa nomor port)
# Ganti ke 8000 kalau port 80 sudah dipakai (misal IIS aktif)
APP_PORT=80
VITE_PORT=5173

DB_DATABASE=pandaeducation
DB_USERNAME=panda
DB_PASSWORD=panda_secret
DB_PORT_HOST=5432

REDIS_PORT_HOST=6379
